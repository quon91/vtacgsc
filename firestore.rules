rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPER FUNCTIONS ─────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isPilot() {
      return isSignedIn() && exists(/databases/$(database)/documents/pilots/$(request.auth.uid));
    }
    function pilotData() {
      return get(/databases/$(database)/documents/pilots/$(request.auth.uid)).data;
    }
    function isActive() {
      return isPilot() && pilotData().status == 'active';
    }
    // Supports BOTH the legacy `role` string and the new `roles` array
    function hasRole(roleId) {
      return isPilot() && (
        (roleId in pilotData().get('roles', [])) ||
        pilotData().get('role', '') == roleId
      );
    }
    function isMasterAdmin() {
      return isActive() && hasRole('master_admin');
    }
    function isWingCommander() {
      return isMasterAdmin() || (isActive() && hasRole('wing_commander'));
    }
    function isWingCommanderOf(wingId) {
      return isMasterAdmin()
        || (isActive() && hasRole('wing_commander') && pilotData().get('wing', '') == wingId);
    }
    function isInstructor() {
      return isWingCommander()
        || (isActive() && hasRole('instructor'))
        || (isActive() && hasRole('sq_commander'));
    }

    // ── CUSTOM-ROLE PERMISSION CHECK ─────────────────────────
    // Reads the role definitions saved by the Roles & Permissions
    // manager (settings/roles) and checks whether ANY of the
    // pilot's roles carries the given permission. This is how
    // custom roles like "GSC Commander" get abilities in rules:
    // tick the permission checkbox on the role, and it works here.
    // Checks the legacy role string plus the first four roles in
    // the roles array (rules can't loop; four is plenty).
    function roleIdHasPerm(cfg, roleId, perm) {
      return roleId in cfg && perm in cfg[roleId].get('permissions', []);
    }
    function hasPerm(perm) {
      return isActive()
        && exists(/databases/$(database)/documents/settings/roles)
        && hasPermInner(get(/databases/$(database)/documents/settings/roles).data.get('roles', {}), perm);
    }
    function hasPermInner(cfg, perm) {
      let rs = pilotData().get('roles', []);
      return roleIdHasPerm(cfg, pilotData().get('role', ''), perm)
        || (rs.size() > 0 && roleIdHasPerm(cfg, rs[0], perm))
        || (rs.size() > 1 && roleIdHasPerm(cfg, rs[1], perm))
        || (rs.size() > 2 && roleIdHasPerm(cfg, rs[2], perm))
        || (rs.size() > 3 && roleIdHasPerm(cfg, rs[3], perm));
    }

    // ── PILOTS ────────────────────────────────────────────────
    match /pilots/{pilotId} {
      // ★ REGISTRATION ★
      // A new member may create THEIR OWN doc, forced to pending.
      // Tolerant of how the register page shapes the fields
      // (role string, roles array, or neither) — but it can never
      // be created as active or with any real role.
      allow create: if isSignedIn()
        && request.auth.uid == pilotId
        && request.resource.data.status == 'pending'
        && request.resource.data.get('role', 'pending') == 'pending'
        && request.resource.data.get('roles', ['pending']).hasOnly(['pending']);

      // ★ PENDING FIX ★
      // Everyone can always read THEIR OWN doc — firebase-config.js
      // does this on every page load, including for pending users
      // (an isActive()-only read rule breaks the pending page).
      // The full roster is readable by active members.
      allow read: if isSignedIn() && (request.auth.uid == pilotId || isActive());

      // Master admin: edit anyone, including roles/rank/status.
      // Wing commanders: manage pilots, but can NEVER grant master_admin.
      // Self: edit own profile, but NEVER own status/roles/rank/assignment.
      allow update: if isMasterAdmin()
        || (isWingCommander()
            && !('master_admin' in request.resource.data.get('roles', []))
            && request.resource.data.get('role', '') != 'master_admin')
        || (isSignedIn() && request.auth.uid == pilotId
            && !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(['status','role','roles','rank','wing','squadron','approvedAt']));

      allow delete: if isMasterAdmin();
    }

    // ── FLIGHTS ───────────────────────────────────────────────
    match /flights/{flightId} {
      allow read: if isActive();
      allow create: if isActive()
        && request.resource.data.pilotUid == request.auth.uid;
      allow update: if isActive()
        && resource.data.pilotUid == request.auth.uid;
      allow delete: if isMasterAdmin() || isInstructor()
        || (isActive() && resource.data.pilotUid == request.auth.uid);
    }

    // ── FLIGHT PLANS (personal to each pilot) ────────────────
    match /flightPlans/{planId} {
      allow create: if isActive()
        && request.resource.data.pilotUid == request.auth.uid;
      allow read, update, delete: if isMasterAdmin()
        || (isActive() && resource.data.pilotUid == request.auth.uid);
    }

    // ── COMMUNITY ROUTES ──────────────────────────────────────
    match /communityRoutes/{routeId} {
      allow read: if isActive();
      allow create: if isActive();
      allow update: if false; // routes are immutable once submitted
      allow delete: if isWingCommander()
        || (isActive() && resource.data.pilotUid == request.auth.uid);
    }

    // ── NOTIFICATIONS ────────────────────────────────────────
    // ★ REGISTRATION FIX ★ — the register flow creates an admin
    // notification when an application is submitted. The deployed
    // rules were missing this collection entirely (deny by default),
    // which killed the whole application submit.
    match /notifications/{notifId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isMasterAdmin();
    }

    // ── SETTINGS (branding, roles, slideshow, webhooks) ──────
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isMasterAdmin();
    }

    // ── NEWS / ANNOUNCEMENTS ─────────────────────────────────
    match /news/{newsId} {
      allow read: if isSignedIn();
      allow write: if isMasterAdmin();
    }

    // ── TRAINING (both collections kept from your two files) ─
    // Writable by: Instructors, Squadron Commanders, Wing
    // Commanders, Master Admin, and ANY custom role holding the
    // "Edit training modules" (manage_training) permission —
    // which is how the GSC Commander role gets access.
    match /training/{recordId} {
      allow read: if isActive();
      allow write: if isMasterAdmin() || isInstructor() || hasPerm('manage_training');
    }
    match /trainingRecords/{recordId} {
      allow read: if isActive();
      allow write: if isMasterAdmin() || isInstructor() || hasPerm('manage_training');
    }

    // ── COMMAND STAFF (Wing Cmdrs, Sq Cmdrs, Master Admin) ───
    // Used for fleet, events, and SOP editing. The GSC Commander
    // (a custom role) qualifies through the permission checkboxes.
    function isCommandStaff() {
      return isMasterAdmin()
        || (isActive() && (hasRole('wing_commander') || hasRole('sq_commander')));
    }

    // ── FLEET (per-wing aircraft registry) ───────────────────
    match /fleet/{aircraftId} {
      allow read: if isActive();
      allow write: if isCommandStaff() || hasPerm('manage_fleet');
    }

    // ── EVENTS ───────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if isActive();
      allow write: if isCommandStaff() || hasPerm('manage_events');
    }

    // ── STANDARD OPERATING PROCEDURES ────────────────────────
    // More specific than settings/{settingId}: command staff can
    // edit the SOP doc even though general settings stay master-only.
    match /settings/sop {
      allow read: if isSignedIn();
      allow write: if isCommandStaff() || hasPerm('edit_sop');
    }

    // ── WINGS (names, callsign pools, logos) ─────────────────
    match /wings/{wingId} {
      allow read: if isSignedIn();
      allow write: if isMasterAdmin() || isWingCommanderOf(wingId);
    }

    // ── AUDIT LOG (immutable) ────────────────────────────────
    match /auditLog/{logId} {
      allow create: if isSignedIn();
      allow read: if isWingCommander();
      allow update, delete: if false;
    }

    // ── SECRET (JT Secret Site private notes) ────────────────
    match /secret/{docId} {
      allow read, write: if isMasterAdmin();
    }

    // Everything not matched above is denied by default.
  }
}
